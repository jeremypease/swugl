# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.

# Required
SECRET_KEY=your-secret-key-here

# Database — leave blank locally to use SQLite; Railway sets this automatically
DATABASE_URL=

# Email via SendGrid
MAIL_ENABLED=false
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@ourpeapod.com

# Set to 'production' on Railway
FLASK_ENV=development

# Stripe billing
# Get these from https://dashboard.stripe.com/apikeys and your product's price IDs
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=
