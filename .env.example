# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.

# Required
SECRET_KEY=your-secret-key-here

# Database — leave blank locally to use SQLite; Railway sets this automatically
DATABASE_URL=

# Email via Resend (https://resend.com)
MAIL_ENABLED=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=Peavines <noreply@ourpeapod.com>

# Set to 'production' on Railway
FLASK_ENV=development

# Set to 'true' to allow public self-serve pod registration; leave unset to require invitation
REGISTRATION_OPEN=true

# Error monitoring (https://sentry.io) — leave blank to disable locally
SENTRY_DSN=

# Support — email address that receives in-app support requests
SUPPORT_EMAIL=you@example.com

# Stripe billing
# Get these from https://dashboard.stripe.com/apikeys and your product's price IDs
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=

# Google OAuth (https://console.cloud.google.com → APIs & Services → Credentials)
# Authorized redirect URI: https://yourpod.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redis — rate-limiter storage shared across gunicorn workers
# Add the Railway Redis service and copy its REDIS_URL; leave blank to use in-memory (dev only)
REDIS_URL=

# Cloudflare R2 photo storage
# Get Account ID from dash.cloudflare.com — R2 sidebar
# Create an API token with R2 Object Read & Write on your bucket
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_BUCKET_NAME=
R2_SECRET_ACCESS_KEY=
# Optional: set after enabling public access on the bucket or adding a custom domain
# e.g. https://pub-xxxx.r2.dev  or  https://photos.ourpeapod.com
R2_PUBLIC_URL=
